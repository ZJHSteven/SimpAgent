{
  "name": "simpagent-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "apps/*/backend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev:console",
    "build": "npm run build:workspaces",
    "test": "npm run test:workspaces",
    "preview": "npm run preview:console",
    "dev:console": "npm run --workspace @simpagent/app-dev-console dev",
    "build:console": "npm run --workspace @simpagent/app-dev-console build",
    "preview:console": "npm run --workspace @simpagent/app-dev-console preview",
    "dev:console-backend": "npm run --workspace @simpagent/dev-console-backend dev",
    "start:console-backend": "npm run --workspace @simpagent/dev-console-backend start",
    "dev:mededu": "npm run --workspace @simpagent/app-mededu-cockpit dev",
    "build:mededu": "npm run --workspace @simpagent/app-mededu-cockpit build",
    "preview:mededu": "npm run --workspace @simpagent/app-mededu-cockpit preview",
    "build:workspaces": "npm run --workspaces --if-present build",
    "test:workspaces": "npm run --workspaces --if-present test",
    "dev:runtime-node": "npm run --workspace @simpagent/runtime-node dev",
    "build:runtime-node": "npm run --workspace @simpagent/runtime-node build",
    "start:runtime-node": "npm run --workspace @simpagent/runtime-node start",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
