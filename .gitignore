# Node 依赖目录体积很大，应通过 package-lock.json 复现，而不是提交进仓库。
node_modules/

# Playwright 运行失败或截图时会生成临时结果目录，不属于源码。
test-results/

# Playwright HTML 报告是本地查看产物，不提交。
playwright-report/

# TypeScript 后端构建产物可以由源码重新生成，不提交。
dist/

# 本地真实模型配置包含 API key，只提交 simpagent.example.toml。
simpagent.toml

# SimpAgent 运行期 trace、thread、响应片段等本地数据，不属于源码。
.simpagent/
