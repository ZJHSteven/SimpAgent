{
  "name": "@simpagent/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types/contracts": {
      "types": "./dist/types/contracts.d.ts",
      "default": "./dist/types/contracts.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "default": "./dist/ports/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.ts",
      "default": "./dist/prompt/index.js"
    },
    "./workflows": {
      "types": "./dist/workflows/index.d.ts",
      "default": "./dist/workflows/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
