[
  {
    "id": "tool.web.search_agent",
    "name": "web_search_agent",
    "description": "用于医学文献与网页检索的统一工具入口。",
    "executorType": "function",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "intent": { "type": "string" }
      },
      "required": ["query"]
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "permissionProfileId": "perm.readonly",
    "timeoutMs": 20000,
    "enabled": true,
    "version": 1
  }
]

